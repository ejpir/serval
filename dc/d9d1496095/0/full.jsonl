{"parentUuid":"630002af-189c-4af0-a5cf-2533cbb7f52b","isSidechain":false,"promptId":"39f1c826-35d1-4f99-bd27-915c0f3e917e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UTVbjyxqj519y5PdAMzcDn","type":"tool_result","content":"1\t// serval-prober/prober.zig\n2\t//! Background Health Prober\n3\t//!\n4\t//! Probes unhealthy backends for recovery using HTTP GET requests.\n5\t//! Uses serval-client for HTTP communication, supporting both plain TCP and TLS.\n6\t//! Blocking I/O is intentional - runs in background thread, not on hot path.\n7\t\n8\tconst std = @import(\"std\");\n9\tconst assert = std.debug.assert;\n10\tconst Io = std.Io;\n11\t\n12\tconst core = @import(\"serval-core\");\n13\tconst net = @import(\"serval-net\");\n14\tconst health_mod = @import(\"serval-health\");\n15\tconst ssl = @import(\"serval-tls\").ssl;\n16\tconst serval_client = @import(\"serval-client\");\n17\tconst scheduler = @import(\"scheduler.zig\");\n18\tconst adapters = @import(\"adapters.zig\");\n19\t\n20\tconst Upstream = core.Upstream;\n21\tconst HealthState = health_mod.HealthState;\n22\tconst DnsResolver = net.DnsResolver;\n23\tconst Client = serval_client.Client;\n24\tconst Request = core.types.Request;\n25\t\n26\t/// Context for background prober thread.\n27\tpub const ProberContext = struct {\n28\t    upstreams: []const Upstream,\n29\t    health: *HealthState,\n30\t    probe_running: *std.atomic.Value(bool),\n31\t    probe_interval_ms: u32,\n32\t    probe_timeout_ms: u32,\n33\t    health_path: []const u8,\n34\t    /// Caller-provided SSL context for TLS probes (null = plain HTTP only).\n35\t    /// Caller owns lifetime: create before starting prober, free after stopping.\n36\t    client_ctx: ?*ssl.SSL_CTX,\n37\t    /// DNS resolver for hostname resolution (caller owns lifetime).\n38\t    dns_resolver: *DnsResolver,\n39\t    /// Allocator for Io runtime (caller owns lifetime).\n40\t    allocator: std.mem.Allocator = std.heap.page_allocator,\n41\t};\n42\t\n43\t\n44\t/// Background probe loop - probes unhealthy backends for recovery.\n45\t/// Runs until probe_running is set to false.\n46\tpub fn probeLoop(ctx: ProberContext) void {\n47\t    assert(ctx.probe_interval_ms > 0);\n48\t    assert(ctx.probe_timeout_ms > 0);\n49\t\n50\t    // One-time init at thread start, no allocation in probe loop.\n51\t    var io_runtime = Io.Threaded.init(ctx.allocator, .{});\n52\t    defer io_runtime.deinit();\n53\t\n54\t    const io = io_runtime.io();\n55\t\n56\t    // Shared client instance for all probes.\n57\t    var client = Client.init(\n58\t        ctx.allocator,\n59\t        ctx.dns_resolver,\n60\t        ctx.client_ctx,\n61\t        false, // prober typically doesn't verify TLS (internal backends)\n62\t    );\n63\t    defer client.deinit();\n64\t\n65\t    var adapter_context = adapters.HttpProbeAdapterContext{\n66\t        .client = &client,\n67\t        .health_path = ctx.health_path,\n68\t    };\n69\t\n70\t    const scheduler_context = scheduler.SchedulerContext{\n71\t        .upstreams = ctx.upstreams,\n72\t        .health = ctx.health,\n73\t        .probe_running = ctx.probe_running,\n74\t        .probe_interval_ms = ctx.probe_interval_ms,\n75\t        .adapter = .{\n76\t            .context = &adapter_context,\n77\t            .probeFn = adapters.httpProbe,\n78\t        },\n79\t    };\n80\t\n81\t    scheduler.runLoopWithIo(scheduler_context, io);\n82\t}\n83\t\n84\t\n85\ttest \"parseHttpStatus - 2xx success codes\" {\n86\t    const testStatus = struct {\n87\t        fn check(response: []const u8) ?u16 {\n88\t            if (!std.mem.startsWith(u8, response, \"HTTP/1.\")) return null;\n89\t            if (response.len < 12) return null;\n90\t            const status_str = response[9..12];\n91\t            return std.fmt.parseInt(u16, status_str, 10) catch null;\n92\t        }\n93\t    }.check;\n94\t\n95\t    // Valid 2xx responses\n96\t    try std.testing.expectEqual(@as(?u16, 200), testStatus(\"HTTP/1.1 200 OK\\r\\n\"));\n97\t    try std.testing.expectEqual(@as(?u16, 201), testStatus(\"HTTP/1.1 201 Created\\r\\n\"));\n98\t    try std.testing.expectEqual(@as(?u16, 204), testStatus(\"HTTP/1.1 204 No Content\\r\\n\"));\n99\t    try std.testing.expectEqual(@as(?u16, 299), testStatus(\"HTTP/1.1 299 Custom\\r\\n\"));\n100\t\n101\t    // Non-2xx responses\n102\t    try std.testing.expectEqual(@as(?u16, 301), testStatus(\"HTTP/1.1 301 Moved\\r\\n\"));\n103\t    try std.testing.expectEqual(@as(?u16, 404), testStatus(\"HTTP/1.1 404 Not Found\\r\\n\"));\n104\t    try std.testing.expectEqual(@as(?u16, 500), testStatus(\"HTTP/1.1 500 Error\\r\\n\"));\n105\t    try std.testing.expectEqual(@as(?u16, 503), testStatus(\"HTTP/1.1 503 Unavailable\\r\\n\"));\n106\t\n107\t    // HTTP/1.0 also valid\n108\t    try std.testing.expectEqual(@as(?u16, 200), testStatus(\"HTTP/1.0 200 OK\\r\\n\"));\n109\t\n110\t    // Invalid responses\n111\t    try std.testing.expectEqual(@as(?u16, null), testStatus(\"HTTP/2.0 200 OK\\r\\n\")); // HTTP/2 prefix\n112\t    try std.testing.expectEqual(@as(?u16, null), testStatus(\"HTTP/1.1 \")); // Too short\n113\t    try std.testing.expectEqual(@as(?u16, null), testStatus(\"INVALID\")); // Not HTTP\n114\t    try std.testing.expectEqual(@as(?u16, null), testStatus(\"\")); // Empty\n115\t}\n116\t\n117\ttest \"isSuccessStatus - 2xx range check\" {\n118\t    const isSuccess = struct {\n119\t        fn check(status: u16) bool {\n120\t            return status >= 200 and status < 300;\n121\t        }\n122\t    }.check;\n123\t\n124\t    // Below 2xx\n125\t    try std.testing.expect(!isSuccess(199));\n126\t\n127\t    // 2xx range\n128\t    try std.testing.expect(isSuccess(200));\n129\t    try std.testing.expect(isSuccess(201));\n130\t    try std.testing.expect(isSuccess(204));\n131\t    try std.testing.expect(isSuccess(250));\n132\t    try std.testing.expect(isSuccess(299));\n133\t\n134\t    // Above 2xx\n135\t    try std.testing.expect(!isSuccess(300));\n136\t    try std.testing.expect(!isSuccess(301));\n137\t    try std.testing.expect(!isSuccess(400));\n138\t    try std.testing.expect(!isSuccess(404));\n139\t    try std.testing.expect(!isSuccess(500));\n140\t    try std.testing.expect(!isSuccess(503));\n141\t}\n142\t\n143\ttest \"ProberContext - field validation\" {\n144\t    var dns_resolver: DnsResolver = undefined;\n145\t    DnsResolver.init(&dns_resolver, .{});\n146\t    const ctx = ProberContext{\n147\t        .upstreams = &[_]Upstream{},\n148\t        .health = undefined,\n149\t        .probe_running = undefined,\n150\t        .probe_interval_ms = 5000,\n151\t        .probe_timeout_ms = 2000,\n152\t        .health_path = \"/health\",\n153\t        .client_ctx = null,\n154\t        .dns_resolver = &dns_resolver,\n155\t    };\n156\t\n157\t    try std.testing.expectEqual(@as(u32, 5000), ctx.probe_interval_ms);\n158\t    try std.testing.expectEqual(@as(u32, 2000), ctx.probe_timeout_ms);\n159\t    try std.testing.expectEqualStrings(\"/health\", ctx.health_path);\n160\t    try std.testing.expect(ctx.client_ctx == null);\n161\t}\n162\t\n163\ttest \"interval calculation\" {\n164\t    const calcInterval = struct {\n165\t        fn calc(interval_ms: u32) struct { s: u64, ns: u64 } {\n166\t            const interval_s: u64 = interval_ms / 1000;\n167\t            const interval_ns: u64 = (@as(u64, interval_ms) % 1000) * 1_000_000;\n168\t            return .{ .s = interval_s, .ns = interval_ns };\n169\t        }\n170\t    }.calc;\n171\t\n172\t    // 5000ms = 5s + 0ns\n173\t    var result = calcInterval(5000);\n174\t    try std.testing.expectEqual(@as(u64, 5), result.s);\n175\t    try std.testing.expectEqual(@as(u64, 0), result.ns);\n176\t\n177\t    // 5500ms = 5s + 500_000_000ns\n178\t    result = calcInterval(5500);\n179\t    try std.testing.expectEqual(@as(u64, 5), result.s);\n180\t    try std.testing.expectEqual(@as(u64, 500_000_000), result.ns);\n181\t\n182\t    // 100ms = 0s + 100_000_000ns\n183\t    result = calcInterval(100);\n184\t    try std.testing.expectEqual(@as(u64, 0), result.s);\n185\t    try std.testing.expectEqual(@as(u64, 100_000_000), result.ns);\n186\t\n187\t    // 1ms = 0s + 1_000_000ns\n188\t    result = calcInterval(1);\n189\t    try std.testing.expectEqual(@as(u64, 0), result.s);\n190\t    try std.testing.expectEqual(@as(u64, 1_000_000), result.ns);\n191\t}\n192\t\n193\ttest \"Request struct creation for probe\" {\n194\t    var request = Request{\n195\t        .method = .GET,\n196\t        .path = \"/health\",\n197\t        .version = .@\"HTTP/1.1\",\n198\t        .headers = .{},\n199\t    };\n200\t\n201\t    try request.headers.put(\"Host\", \"backend1.example.com\");\n202\t    try request.headers.put(\"Connection\", \"close\");\n203\t    try request.headers.put(\"User-Agent\", \"serval-prober/1.0\");\n204\t\n205\t    try std.testing.expectEqual(core.types.Method.GET, request.method);\n206\t    try std.testing.expectEqualStrings(\"/health\", request.path);\n207\t    try std.testing.expectEqual(@as(usize, 3), request.headers.count);\n208\t\n209\t    const host = request.headers.get(\"Host\");\n210\t    try std.testing.expect(host != null);\n211\t    try std.testing.expectEqualStrings(\"backend1.example.com\", host.?);\n212\t}\n213\t\n214\ttest \"Upstream struct with TLS flag\" {\n215\t    const upstream_tls = Upstream{\n216\t        .host = \"secure.example.com\",\n217\t        .port = 443,\n218\t        .tls = true,\n219\t        .idx = 0,\n220\t    };\n221\t\n222\t    try std.testing.expectEqualStrings(\"secure.example.com\", upstream_tls.host);\n223\t    try std.testing.expectEqual(@as(u16, 443), upstream_tls.port);\n224\t    try std.testing.expect(upstream_tls.tls);\n225\t\n226\t    const upstream_plain = Upstream{\n227\t        .host = \"backend.local\",\n228\t        .port = 8080,\n229\t        .tls = false,\n230\t        .idx = 1,\n231\t    };\n232\t\n233\t    try std.testing.expectEqualStrings(\"backend.local\", upstream_plain.host);\n234\t    try std.testing.expectEqual(@as(u16, 8080), upstream_plain.port);\n235\t    try std.testing.expect(!upstream_plain.tls);\n236\t}\n237\t\n238\ttest \"header buffer size is reasonable\" {\n239\t    // Buffer must fit status line (~17 bytes) plus minimal headers.\n240\t    const header_buf_size: usize = 1024;\n241\t    try std.testing.expect(header_buf_size >= 256);\n242\t    try std.testing.expect(header_buf_size <= 8192);\n243\t}\n244\t"}]},"uuid":"24c3718c-bc12-47b4-af31-7003591bef5a","timestamp":"2026-03-29T16:26:08.088Z","toolUseResult":{"type":"text","file":{"filePath":"/home/nick/repos/serval/serval-prober/prober.zig","content":"// serval-prober/prober.zig\n//! Background Health Prober\n//!\n//! Probes unhealthy backends for recovery using HTTP GET requests.\n//! Uses serval-client for HTTP communication, supporting both plain TCP and TLS.\n//! Blocking I/O is intentional - runs in background thread, not on hot path.\n\nconst std = @import(\"std\");\nconst assert = std.debug.assert;\nconst Io = std.Io;\n\nconst core = @import(\"serval-core\");\nconst net = @import(\"serval-net\");\nconst health_mod = @import(\"serval-health\");\nconst ssl = @import(\"serval-tls\").ssl;\nconst serval_client = @import(\"serval-client\");\nconst scheduler = @import(\"scheduler.zig\");\nconst adapters = @import(\"adapters.zig\");\n\nconst Upstream = core.Upstream;\nconst HealthState = health_mod.HealthState;\nconst DnsResolver = net.DnsResolver;\nconst Client = serval_client.Client;\nconst Request = core.types.Request;\n\n/// Context for background prober thread.\npub const ProberContext = struct {\n    upstreams: []const Upstream,\n    health: *HealthState,\n    probe_running: *std.atomic.Value(bool),\n    probe_interval_ms: u32,\n    probe_timeout_ms: u32,\n    health_path: []const u8,\n    /// Caller-provided SSL context for TLS probes (null = plain HTTP only).\n    /// Caller owns lifetime: create before starting prober, free after stopping.\n    client_ctx: ?*ssl.SSL_CTX,\n    /// DNS resolver for hostname resolution (caller owns lifetime).\n    dns_resolver: *DnsResolver,\n    /// Allocator for Io runtime (caller owns lifetime).\n    allocator: std.mem.Allocator = std.heap.page_allocator,\n};\n\n\n/// Background probe loop - probes unhealthy backends for recovery.\n/// Runs until probe_running is set to false.\npub fn probeLoop(ctx: ProberContext) void {\n    assert(ctx.probe_interval_ms > 0);\n    assert(ctx.probe_timeout_ms > 0);\n\n    // One-time init at thread start, no allocation in probe loop.\n    var io_runtime = Io.Threaded.init(ctx.allocator, .{});\n    defer io_runtime.deinit();\n\n    const io = io_runtime.io();\n\n    // Shared client instance for all probes.\n    var client = Client.init(\n        ctx.allocator,\n        ctx.dns_resolver,\n        ctx.client_ctx,\n        false, // prober typically doesn't verify TLS (internal backends)\n    );\n    defer client.deinit();\n\n    var adapter_context = adapters.HttpProbeAdapterContext{\n        .client = &client,\n        .health_path = ctx.health_path,\n    };\n\n    const scheduler_context = scheduler.SchedulerContext{\n        .upstreams = ctx.upstreams,\n        .health = ctx.health,\n        .probe_running = ctx.probe_running,\n        .probe_interval_ms = ctx.probe_interval_ms,\n        .adapter = .{\n            .context = &adapter_context,\n            .probeFn = adapters.httpProbe,\n        },\n    };\n\n    scheduler.runLoopWithIo(scheduler_context, io);\n}\n\n\ntest \"parseHttpStatus - 2xx success codes\" {\n    const testStatus = struct {\n        fn check(response: []const u8) ?u16 {\n            if (!std.mem.startsWith(u8, response, \"HTTP/1.\")) return null;\n            if (response.len < 12) return null;\n            const status_str = response[9..12];\n            return std.fmt.parseInt(u16, status_str, 10) catch null;\n        }\n    }.check;\n\n    // Valid 2xx responses\n    try std.testing.expectEqual(@as(?u16, 200), testStatus(\"HTTP/1.1 200 OK\\r\\n\"));\n    try std.testing.expectEqual(@as(?u16, 201), testStatus(\"HTTP/1.1 201 Created\\r\\n\"));\n    try std.testing.expectEqual(@as(?u16, 204), testStatus(\"HTTP/1.1 204 No Content\\r\\n\"));\n    try std.testing.expectEqual(@as(?u16, 299), testStatus(\"HTTP/1.1 299 Custom\\r\\n\"));\n\n    // Non-2xx responses\n    try std.testing.expectEqual(@as(?u16, 301), testStatus(\"HTTP/1.1 301 Moved\\r\\n\"));\n    try std.testing.expectEqual(@as(?u16, 404), testStatus(\"HTTP/1.1 404 Not Found\\r\\n\"));\n    try std.testing.expectEqual(@as(?u16, 500), testStatus(\"HTTP/1.1 500 Error\\r\\n\"));\n    try std.testing.expectEqual(@as(?u16, 503), testStatus(\"HTTP/1.1 503 Unavailable\\r\\n\"));\n\n    // HTTP/1.0 also valid\n    try std.testing.expectEqual(@as(?u16, 200), testStatus(\"HTTP/1.0 200 OK\\r\\n\"));\n\n    // Invalid responses\n    try std.testing.expectEqual(@as(?u16, null), testStatus(\"HTTP/2.0 200 OK\\r\\n\")); // HTTP/2 prefix\n    try std.testing.expectEqual(@as(?u16, null), testStatus(\"HTTP/1.1 \")); // Too short\n    try std.testing.expectEqual(@as(?u16, null), testStatus(\"INVALID\")); // Not HTTP\n    try std.testing.expectEqual(@as(?u16, null), testStatus(\"\")); // Empty\n}\n\ntest \"isSuccessStatus - 2xx range check\" {\n    const isSuccess = struct {\n        fn check(status: u16) bool {\n            return status >= 200 and status < 300;\n        }\n    }.check;\n\n    // Below 2xx\n    try std.testing.expect(!isSuccess(199));\n\n    // 2xx range\n    try std.testing.expect(isSuccess(200));\n    try std.testing.expect(isSuccess(201));\n    try std.testing.expect(isSuccess(204));\n    try std.testing.expect(isSuccess(250));\n    try std.testing.expect(isSuccess(299));\n\n    // Above 2xx\n    try std.testing.expect(!isSuccess(300));\n    try std.testing.expect(!isSuccess(301));\n    try std.testing.expect(!isSuccess(400));\n    try std.testing.expect(!isSuccess(404));\n    try std.testing.expect(!isSuccess(500));\n    try std.testing.expect(!isSuccess(503));\n}\n\ntest \"ProberContext - field validation\" {\n    var dns_resolver: DnsResolver = undefined;\n    DnsResolver.init(&dns_resolver, .{});\n    const ctx = ProberContext{\n        .upstreams = &[_]Upstream{},\n        .health = undefined,\n        .probe_running = undefined,\n        .probe_interval_ms = 5000,\n        .probe_timeout_ms = 2000,\n        .health_path = \"/health\",\n        .client_ctx = null,\n        .dns_resolver = &dns_resolver,\n    };\n\n    try std.testing.expectEqual(@as(u32, 5000), ctx.probe_interval_ms);\n    try std.testing.expectEqual(@as(u32, 2000), ctx.probe_timeout_ms);\n    try std.testing.expectEqualStrings(\"/health\", ctx.health_path);\n    try std.testing.expect(ctx.client_ctx == null);\n}\n\ntest \"interval calculation\" {\n    const calcInterval = struct {\n        fn calc(interval_ms: u32) struct { s: u64, ns: u64 } {\n            const interval_s: u64 = interval_ms / 1000;\n            const interval_ns: u64 = (@as(u64, interval_ms) % 1000) * 1_000_000;\n            return .{ .s = interval_s, .ns = interval_ns };\n        }\n    }.calc;\n\n    // 5000ms = 5s + 0ns\n    var result = calcInterval(5000);\n    try std.testing.expectEqual(@as(u64, 5), result.s);\n    try std.testing.expectEqual(@as(u64, 0), result.ns);\n\n    // 5500ms = 5s + 500_000_000ns\n    result = calcInterval(5500);\n    try std.testing.expectEqual(@as(u64, 5), result.s);\n    try std.testing.expectEqual(@as(u64, 500_000_000), result.ns);\n\n    // 100ms = 0s + 100_000_000ns\n    result = calcInterval(100);\n    try std.testing.expectEqual(@as(u64, 0), result.s);\n    try std.testing.expectEqual(@as(u64, 100_000_000), result.ns);\n\n    // 1ms = 0s + 1_000_000ns\n    result = calcInterval(1);\n    try std.testing.expectEqual(@as(u64, 0), result.s);\n    try std.testing.expectEqual(@as(u64, 1_000_000), result.ns);\n}\n\ntest \"Request struct creation for probe\" {\n    var request = Request{\n        .method = .GET,\n        .path = \"/health\",\n        .version = .@\"HTTP/1.1\",\n        .headers = .{},\n    };\n\n    try request.headers.put(\"Host\", \"backend1.example.com\");\n    try request.headers.put(\"Connection\", \"close\");\n    try request.headers.put(\"User-Agent\", \"serval-prober/1.0\");\n\n    try std.testing.expectEqual(core.types.Method.GET, request.method);\n    try std.testing.expectEqualStrings(\"/health\", request.path);\n    try std.testing.expectEqual(@as(usize, 3), request.headers.count);\n\n    const host = request.headers.get(\"Host\");\n    try std.testing.expect(host != null);\n    try std.testing.expectEqualStrings(\"backend1.example.com\", host.?);\n}\n\ntest \"Upstream struct with TLS flag\" {\n    const upstream_tls = Upstream{\n        .host = \"secure.example.com\",\n        .port = 443,\n        .tls = true,\n        .idx = 0,\n    };\n\n    try std.testing.expectEqualStrings(\"secure.example.com\", upstream_tls.host);\n    try std.testing.expectEqual(@as(u16, 443), upstream_tls.port);\n    try std.testing.expect(upstream_tls.tls);\n\n    const upstream_plain = Upstream{\n        .host = \"backend.local\",\n        .port = 8080,\n        .tls = false,\n        .idx = 1,\n    };\n\n    try std.testing.expectEqualStrings(\"backend.local\", upstream_plain.host);\n    try std.testing.expectEqual(@as(u16, 8080), upstream_plain.port);\n    try std.testing.expect(!upstream_plain.tls);\n}\n\ntest \"header buffer size is reasonable\" {\n    // Buffer must fit status line (~17 bytes) plus minimal headers.\n    const header_buf_size: usize = 1024;\n    try std.testing.expect(header_buf_size >= 256);\n    try std.testing.expect(header_buf_size <= 8192);\n}\n","numLines":244,"startLine":1,"totalLines":244}},"sourceToolAssistantUUID":"630002af-189c-4af0-a5cf-2533cbb7f52b","userType":"external","entrypoint":"cli","cwd":"/home/nick/repos/serval","sessionId":"646a4f49-bebb-4328-acf0-8f573ea592f5","version":"2.1.86","gitBranch":"main","slug":"graceful-swimming-stream"}
