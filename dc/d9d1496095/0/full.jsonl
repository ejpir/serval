{"parentUuid":"35be3054-7c1c-46ac-aaf2-b859ef0d21b4","isSidechain":false,"promptId":"39f1c826-35d1-4f99-bd27-915c0f3e917e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P2egJRZAVbCujLD9g9c79M","type":"tool_result","content":"1\t//! Unified Health State\n2\t//!\n3\t//! Combined health bitmap and threshold-based state transitions.\n4\t//! Designed to be embedded directly in handlers without pointers.\n5\t//! TigerStyle: Cache-line aligned, no allocation, bounded loops.\n6\t\n7\tconst std = @import(\"std\");\n8\tconst assert = std.debug.assert;\n9\tconst config = @import(\"serval-core\").config;\n10\t\n11\tpub const MAX_UPSTREAMS: u8 = config.MAX_UPSTREAMS;\n12\tpub const UpstreamIndex = config.UpstreamIndex;\n13\t\n14\t/// Cache line size for alignment to prevent false sharing.\n15\tconst CACHE_LINE_BYTES: usize = 64;\n16\t\n17\t/// Unified health state with embedded threshold tracking.\n18\t/// Embeddable in handlers without self-referential pointers.\n19\tpub const HealthState = struct {\n20\t    /// Health bitmap: bit N set = backend N healthy.\n21\t    health_bitmap: std.atomic.Value(u64) align(CACHE_LINE_BYTES),\n22\t\n23\t    /// Consecutive failure counts per backend.\n24\t    failure_counts: [MAX_UPSTREAMS]u8,\n25\t\n26\t    /// Consecutive success counts per backend.\n27\t    success_counts: [MAX_UPSTREAMS]u8,\n28\t\n29\t    /// Number of configured backends (prevents out-of-bounds).\n30\t    backend_count: u8,\n31\t\n32\t    /// Consecutive failures required to mark unhealthy.\n33\t    unhealthy_threshold: u8,\n34\t\n35\t    /// Consecutive successes required to mark healthy.\n36\t    healthy_threshold: u8,\n37\t\n38\t    // Compile-time verification\n39\t    comptime {\n40\t        assert(@alignOf(HealthState) == CACHE_LINE_BYTES);\n41\t        assert(MAX_UPSTREAMS <= 64); // Bitmap is u64\n42\t    }\n43\t\n44\t    /// Compute bitmask for first `count` backends.\n45\t    /// Returns mask where bits 0..(count-1) are set.\n46\t    fn backendMask(count: u8) u64 {\n47\t        assert(count <= MAX_UPSTREAMS);\n48\t        if (count == 0) return 0;\n49\t        if (count >= 64) return std.math.maxInt(u64);\n50\t        return (@as(u64, 1) << @as(u6, @intCast(count))) - 1;\n51\t    }\n52\t\n53\t    /// Initialize with backend count and thresholds.\n54\t    /// Only first backend_count backends start healthy.\n55\t    pub fn init(backend_count: u8, unhealthy_threshold: u8, healthy_threshold: u8) HealthState {\n56\t        assert(backend_count <= MAX_UPSTREAMS);\n57\t        assert(unhealthy_threshold > 0);\n58\t        assert(healthy_threshold > 0);\n59\t\n60\t        return HealthState{\n61\t            .health_bitmap = std.atomic.Value(u64).init(backendMask(backend_count)),\n62\t            .failure_counts = std.mem.zeroes([MAX_UPSTREAMS]u8),\n63\t            .success_counts = std.mem.zeroes([MAX_UPSTREAMS]u8),\n64\t            .backend_count = backend_count,\n65\t            .unhealthy_threshold = unhealthy_threshold,\n66\t            .healthy_threshold = healthy_threshold,\n67\t        };\n68\t    }\n69\t\n70\t    /// Record successful request/probe for backend.\n71\t    /// Resets failure counter; increments success counter if unhealthy.\n72\t    /// Transitions to healthy when success threshold is reached.\n73\t    pub inline fn recordSuccess(self: *HealthState, idx: UpstreamIndex) void {\n74\t        assert(idx < self.backend_count);\n75\t\n76\t        // Reset failure counter on any success\n77\t        self.failure_counts[idx] = 0;\n78\t\n79\t        // Fast path: already healthy\n80\t        if (self.isHealthy(idx)) return;\n81\t\n82\t        // Increment success counter (saturating)\n83\t        const new_count = self.success_counts[idx] +| 1;\n84\t        self.success_counts[idx] = new_count;\n85\t\n86\t        // Transition to healthy if threshold reached\n87\t        if (new_count >= self.healthy_threshold) {\n88\t            self.markHealthy(idx);\n89\t            self.success_counts[idx] = 0;\n90\t        }\n91\t    }\n92\t\n93\t    /// Record failed request/probe for backend.\n94\t    /// Resets success counter; increments failure counter if healthy.\n95\t    /// Transitions to unhealthy when failure threshold is reached.\n96\t    pub inline fn recordFailure(self: *HealthState, idx: UpstreamIndex) void {\n97\t        assert(idx < self.backend_count);\n98\t\n99\t        // Reset success counter on any failure\n100\t        self.success_counts[idx] = 0;\n101\t\n102\t        // Fast path: already unhealthy\n103\t        if (!self.isHealthy(idx)) return;\n104\t\n105\t        // Increment failure counter (saturating)\n106\t        const new_count = self.failure_counts[idx] +| 1;\n107\t        self.failure_counts[idx] = new_count;\n108\t\n109\t        // Transition to unhealthy if threshold reached\n110\t        if (new_count >= self.unhealthy_threshold) {\n111\t            self.markUnhealthy(idx);\n112\t            self.failure_counts[idx] = 0;\n113\t        }\n114\t    }\n115\t\n116\t    /// Check if backend is healthy (atomic read).\n117\t    pub inline fn isHealthy(self: *const HealthState, idx: UpstreamIndex) bool {\n118\t        assert(idx < self.backend_count);\n119\t        const bitmap = self.health_bitmap.load(.acquire);\n120\t        const mask: u64 = @as(u64, 1) << idx;\n121\t        return (bitmap & mask) != 0;\n122\t    }\n123\t\n124\t    /// Count healthy backends (atomic read).\n125\t    pub fn countHealthy(self: *const HealthState) u32 {\n126\t        const bitmap = self.health_bitmap.load(.acquire);\n127\t        return @popCount(bitmap & backendMask(self.backend_count));\n128\t    }\n129\t\n130\t    /// Find Nth healthy backend, wrapping around.\n131\t    /// Returns null only if no healthy backends exist.\n132\t    /// Used for round-robin selection across healthy backends.\n133\t    pub fn findNthHealthy(self: *const HealthState, n: u32) ?UpstreamIndex {\n134\t        var bitmap = self.health_bitmap.load(.acquire) & backendMask(self.backend_count);\n135\t\n136\t        const healthy_count = @popCount(bitmap);\n137\t        if (healthy_count == 0) return null;\n138\t\n139\t        var remaining = n % healthy_count;\n140\t        var iterations: u8 = 0;\n141\t\n142\t        while (bitmap != 0 and iterations < MAX_UPSTREAMS) : (iterations += 1) {\n143\t            const lowest_bit_pos: u7 = @ctz(bitmap);\n144\t            if (remaining == 0) {\n145\t                assert(lowest_bit_pos < 64);\n146\t                return @intCast(lowest_bit_pos);\n147\t            }\n148\t            bitmap &= bitmap - 1;\n149\t            remaining -= 1;\n150\t        }\n151\t\n152\t        assert(false);\n153\t        return null;\n154\t    }\n155\t\n156\t    /// Find first healthy backend, optionally excluding one.\n157\t    /// Useful for failover when current backend fails.\n158\t    pub fn findFirstHealthy(self: *const HealthState, exclude_idx: ?UpstreamIndex) ?UpstreamIndex {\n159\t        var bitmap = self.health_bitmap.load(.acquire) & backendMask(self.backend_count);\n160\t\n161\t        if (exclude_idx) |idx| {\n162\t            assert(idx < self.backend_count);\n163\t            bitmap &= ~(@as(u64, 1) << idx);\n164\t        }\n165\t\n166\t        if (bitmap == 0) return null;\n167\t\n168\t        const first: u7 = @ctz(bitmap);\n169\t        assert(first < 64);\n170\t        return @intCast(first);\n171\t    }\n172\t\n173\t    /// Mark backend as healthy (atomic set bit).\n174\t    fn markHealthy(self: *HealthState, idx: UpstreamIndex) void {\n175\t        assert(idx < self.backend_count);\n176\t        const mask: u64 = @as(u64, 1) << idx;\n177\t        _ = self.health_bitmap.fetchOr(mask, .release);\n178\t    }\n179\t\n180\t    /// Mark backend as unhealthy (atomic clear bit).\n181\t    fn markUnhealthy(self: *HealthState, idx: UpstreamIndex) void {\n182\t        assert(idx < self.backend_count);\n183\t        const mask: u64 = @as(u64, 1) << idx;\n184\t        _ = self.health_bitmap.fetchAnd(~mask, .release);\n185\t    }\n186\t\n187\t    /// Reset all backends to healthy and clear counters.\n188\t    pub fn reset(self: *HealthState) void {\n189\t        self.health_bitmap.store(backendMask(self.backend_count), .release);\n190\t        self.failure_counts = std.mem.zeroes([MAX_UPSTREAMS]u8);\n191\t        self.success_counts = std.mem.zeroes([MAX_UPSTREAMS]u8);\n192\t    }\n193\t};\n194\t\n195\t// =============================================================================\n196\t// Tests\n197\t// =============================================================================\n198\t\n199\ttest \"HealthState alignment\" {\n200\t    try std.testing.expectEqual(@as(usize, CACHE_LINE_BYTES), @alignOf(HealthState));\n201\t}\n202\t\n203\ttest \"HealthState init with backend count\" {\n204\t    const state = HealthState.init(3, 3, 2);\n205\t\n206\t    try std.testing.expectEqual(@as(u32, 3), state.countHealthy());\n207\t    try std.testing.expect(state.isHealthy(0));\n208\t    try std.testing.expect(state.isHealthy(1));\n209\t    try std.testing.expect(state.isHealthy(2));\n210\t    try std.testing.expectEqual(@as(u8, 3), state.unhealthy_threshold);\n211\t    try std.testing.expectEqual(@as(u8, 2), state.healthy_threshold);\n212\t}\n213\t\n214\ttest \"HealthState init with zero backends\" {\n215\t    const state = HealthState.init(0, 3, 2);\n216\t    try std.testing.expectEqual(@as(u32, 0), state.countHealthy());\n217\t}\n218\t\n219\ttest \"HealthState init with max backends\" {\n220\t    const state = HealthState.init(MAX_UPSTREAMS, 3, 2);\n221\t    try std.testing.expectEqual(@as(u32, MAX_UPSTREAMS), state.countHealthy());\n222\t    try std.testing.expect(state.isHealthy(0));\n223\t    try std.testing.expect(state.isHealthy(MAX_UPSTREAMS - 1));\n224\t}\n225\t\n226\ttest \"HealthState recordFailure transitions after threshold\" {\n227\t    var state = HealthState.init(3, 3, 2);\n228\t\n229\t    // Start healthy\n230\t    try std.testing.expect(state.isHealthy(0));\n231\t\n232\t    // First two failures - still healthy\n233\t    state.recordFailure(0);\n234\t    try std.testing.expect(state.isHealthy(0));\n235\t    try std.testing.expectEqual(@as(u8, 1), state.failure_counts[0]);\n236\t\n237\t    state.recordFailure(0);\n238\t    try std.testing.expect(state.isHealthy(0));\n239\t    try std.testing.expectEqual(@as(u8, 2), state.failure_counts[0]);\n240\t\n241\t    // Third failure - reaches threshold, now unhealthy\n242\t    state.recordFailure(0);\n243\t    try std.testing.expect(!state.isHealthy(0));\n244\t    try std.testing.expectEqual(@as(u8, 0), state.failure_counts[0]);\n245\t}\n246\t\n247\ttest \"HealthState recordSuccess transitions after threshold\" {\n248\t    var state = HealthState.init(3, 3, 2);\n249\t\n250\t    // Mark backend unhealthy via failures\n251\t    state.recordFailure(0);\n252\t    state.recordFailure(0);\n253\t    state.recordFailure(0);\n254\t    try std.testing.expect(!state.isHealthy(0));\n255\t\n256\t    // First success - still unhealthy\n257\t    state.recordSuccess(0);\n258\t    try std.testing.expect(!state.isHealthy(0));\n259\t    try std.testing.expectEqual(@as(u8, 1), state.success_counts[0]);\n260\t\n261\t    // Second success - reaches threshold, now healthy\n262\t    state.recordSuccess(0);\n263\t    try std.testing.expect(state.isHealthy(0));\n264\t    try std.testing.expectEqual(@as(u8, 0), state.success_counts[0]);\n265\t}\n266\t\n267\ttest \"HealthState success resets failure counter\" {\n268\t    var state = HealthState.init(3, 3, 2);\n269\t\n270\t    // Accumulate failures\n271\t    state.recordFailure(0);\n272\t    state.recordFailure(0);\n273\t    try std.testing.expectEqual(@as(u8, 2), state.failure_counts[0]);\n274\t\n275\t    // Single success resets failure counter\n276\t    state.recordSuccess(0);\n277\t    try std.testing.expectEqual(@as(u8, 0), state.failure_counts[0]);\n278\t}\n279\t\n280\ttest \"HealthState failure resets success counter\" {\n281\t    var state = HealthState.init(3, 3, 2);\n282\t\n283\t    // Mark unhealthy first\n284\t    state.recordFailure(0);\n285\t    state.recordFailure(0);\n286\t    state.recordFailure(0);\n287\t    try std.testing.expect(!state.isHealthy(0));\n288\t\n289\t    // Accumulate successes\n290\t    state.recordSuccess(0);\n291\t    try std.testing.expectEqual(@as(u8, 1), state.success_counts[0]);\n292\t\n293\t    // Single failure resets success counter\n294\t    state.recordFailure(0);\n295\t    try std.testing.expectEqual(@as(u8, 0), state.success_counts[0]);\n296\t}\n297\t\n298\ttest \"HealthState findNthHealthy\" {\n299\t    var state = HealthState.init(5, 3, 2);\n300\t\n301\t    // Mark some unhealthy: 0, 2 unhealthy; 1, 3, 4 healthy\n302\t    state.recordFailure(0);\n303\t    state.recordFailure(0);\n304\t    state.recordFailure(0);\n305\t    state.recordFailure(2);\n306\t    state.recordFailure(2);\n307\t    state.recordFailure(2);\n308\t\n309\t    try std.testing.expectEqual(@as(?UpstreamIndex, 1), state.findNthHealthy(0));\n310\t    try std.testing.expectEqual(@as(?UpstreamIndex, 3), state.findNthHealthy(1));\n311\t    try std.testing.expectEqual(@as(?UpstreamIndex, 4), state.findNthHealthy(2));\n312\t    // Wraps around\n313\t    try std.testing.expectEqual(@as(?UpstreamIndex, 1), state.findNthHealthy(3));\n314\t}\n315\t\n316\ttest \"HealthState findFirstHealthy\" {\n317\t    var state = HealthState.init(5, 3, 2);\n318\t\n319\t    try std.testing.expectEqual(@as(?UpstreamIndex, 0), state.findFirstHealthy(null));\n320\t    try std.testing.expectEqual(@as(?UpstreamIndex, 1), state.findFirstHealthy(0));\n321\t\n322\t    // Mark 0-1 unhealthy\n323\t    state.recordFailure(0);\n324\t    state.recordFailure(0);\n325\t    state.recordFailure(0);\n326\t    state.recordFailure(1);\n327\t    state.recordFailure(1);\n328\t    state.recordFailure(1);\n329\t\n330\t    try std.testing.expectEqual(@as(?UpstreamIndex, 2), state.findFirstHealthy(null));\n331\t}\n332\t\n333\ttest \"HealthState findFirstHealthy returns null when all unhealthy\" {\n334\t    var state = HealthState.init(2, 3, 2);\n335\t\n336\t    // Mark all unhealthy\n337\t    state.recordFailure(0);\n338\t    state.recordFailure(0);\n339\t    state.recordFailure(0);\n340\t    state.recordFailure(1);\n341\t    state.recordFailure(1);\n342\t    state.recordFailure(1);\n343\t\n344\t    try std.testing.expectEqual(@as(?UpstreamIndex, null), state.findFirstHealthy(null));\n345\t}\n346\t\n347\ttest \"HealthState reset\" {\n348\t    var state = HealthState.init(3, 3, 2);\n349\t\n350\t    // Mark all unhealthy\n351\t    state.recordFailure(0);\n352\t    state.recordFailure(0);\n353\t    state.recordFailure(0);\n354\t    state.recordFailure(1);\n355\t    state.recordFailure(1);\n356\t    state.recordFailure(1);\n357\t\n358\t    try std.testing.expectEqual(@as(u32, 1), state.countHealthy());\n359\t\n360\t    // Reset\n361\t    state.reset();\n362\t\n363\t    try std.testing.expectEqual(@as(u32, 3), state.countHealthy());\n364\t    try std.testing.expect(state.isHealthy(0));\n365\t    try std.testing.expect(state.isHealthy(1));\n366\t    try std.testing.expect(state.isHealthy(2));\n367\t}\n368\t\n369\ttest \"HealthState fast path when already in target state\" {\n370\t    var state = HealthState.init(3, 3, 2);\n371\t\n372\t    // Already healthy - recordSuccess should be fast path\n373\t    try std.testing.expect(state.isHealthy(0));\n374\t    state.recordSuccess(0);\n375\t    // Success counter should not increment when already healthy\n376\t    try std.testing.expectEqual(@as(u8, 0), state.success_counts[0]);\n377\t\n378\t    // Mark unhealthy\n379\t    state.recordFailure(0);\n380\t    state.recordFailure(0);\n381\t    state.recordFailure(0);\n382\t    try std.testing.expect(!state.isHealthy(0));\n383\t\n384\t    // Already unhealthy - recordFailure should be fast path\n385\t    state.recordFailure(0);\n386\t    // Failure counter should not increment when already unhealthy\n387\t    try std.testing.expectEqual(@as(u8, 0), state.failure_counts[0]);\n388\t}\n389\t"}]},"uuid":"96a380c2-3e4c-4fca-88cf-2ff2bca6e2da","timestamp":"2026-03-29T16:25:18.918Z","toolUseResult":{"type":"text","file":{"filePath":"/home/nick/repos/serval/serval-health/health_state.zig","content":"//! Unified Health State\n//!\n//! Combined health bitmap and threshold-based state transitions.\n//! Designed to be embedded directly in handlers without pointers.\n//! TigerStyle: Cache-line aligned, no allocation, bounded loops.\n\nconst std = @import(\"std\");\nconst assert = std.debug.assert;\nconst config = @import(\"serval-core\").config;\n\npub const MAX_UPSTREAMS: u8 = config.MAX_UPSTREAMS;\npub const UpstreamIndex = config.UpstreamIndex;\n\n/// Cache line size for alignment to prevent false sharing.\nconst CACHE_LINE_BYTES: usize = 64;\n\n/// Unified health state with embedded threshold tracking.\n/// Embeddable in handlers without self-referential pointers.\npub const HealthState = struct {\n    /// Health bitmap: bit N set = backend N healthy.\n    health_bitmap: std.atomic.Value(u64) align(CACHE_LINE_BYTES),\n\n    /// Consecutive failure counts per backend.\n    failure_counts: [MAX_UPSTREAMS]u8,\n\n    /// Consecutive success counts per backend.\n    success_counts: [MAX_UPSTREAMS]u8,\n\n    /// Number of configured backends (prevents out-of-bounds).\n    backend_count: u8,\n\n    /// Consecutive failures required to mark unhealthy.\n    unhealthy_threshold: u8,\n\n    /// Consecutive successes required to mark healthy.\n    healthy_threshold: u8,\n\n    // Compile-time verification\n    comptime {\n        assert(@alignOf(HealthState) == CACHE_LINE_BYTES);\n        assert(MAX_UPSTREAMS <= 64); // Bitmap is u64\n    }\n\n    /// Compute bitmask for first `count` backends.\n    /// Returns mask where bits 0..(count-1) are set.\n    fn backendMask(count: u8) u64 {\n        assert(count <= MAX_UPSTREAMS);\n        if (count == 0) return 0;\n        if (count >= 64) return std.math.maxInt(u64);\n        return (@as(u64, 1) << @as(u6, @intCast(count))) - 1;\n    }\n\n    /// Initialize with backend count and thresholds.\n    /// Only first backend_count backends start healthy.\n    pub fn init(backend_count: u8, unhealthy_threshold: u8, healthy_threshold: u8) HealthState {\n        assert(backend_count <= MAX_UPSTREAMS);\n        assert(unhealthy_threshold > 0);\n        assert(healthy_threshold > 0);\n\n        return HealthState{\n            .health_bitmap = std.atomic.Value(u64).init(backendMask(backend_count)),\n            .failure_counts = std.mem.zeroes([MAX_UPSTREAMS]u8),\n            .success_counts = std.mem.zeroes([MAX_UPSTREAMS]u8),\n            .backend_count = backend_count,\n            .unhealthy_threshold = unhealthy_threshold,\n            .healthy_threshold = healthy_threshold,\n        };\n    }\n\n    /// Record successful request/probe for backend.\n    /// Resets failure counter; increments success counter if unhealthy.\n    /// Transitions to healthy when success threshold is reached.\n    pub inline fn recordSuccess(self: *HealthState, idx: UpstreamIndex) void {\n        assert(idx < self.backend_count);\n\n        // Reset failure counter on any success\n        self.failure_counts[idx] = 0;\n\n        // Fast path: already healthy\n        if (self.isHealthy(idx)) return;\n\n        // Increment success counter (saturating)\n        const new_count = self.success_counts[idx] +| 1;\n        self.success_counts[idx] = new_count;\n\n        // Transition to healthy if threshold reached\n        if (new_count >= self.healthy_threshold) {\n            self.markHealthy(idx);\n            self.success_counts[idx] = 0;\n        }\n    }\n\n    /// Record failed request/probe for backend.\n    /// Resets success counter; increments failure counter if healthy.\n    /// Transitions to unhealthy when failure threshold is reached.\n    pub inline fn recordFailure(self: *HealthState, idx: UpstreamIndex) void {\n        assert(idx < self.backend_count);\n\n        // Reset success counter on any failure\n        self.success_counts[idx] = 0;\n\n        // Fast path: already unhealthy\n        if (!self.isHealthy(idx)) return;\n\n        // Increment failure counter (saturating)\n        const new_count = self.failure_counts[idx] +| 1;\n        self.failure_counts[idx] = new_count;\n\n        // Transition to unhealthy if threshold reached\n        if (new_count >= self.unhealthy_threshold) {\n            self.markUnhealthy(idx);\n            self.failure_counts[idx] = 0;\n        }\n    }\n\n    /// Check if backend is healthy (atomic read).\n    pub inline fn isHealthy(self: *const HealthState, idx: UpstreamIndex) bool {\n        assert(idx < self.backend_count);\n        const bitmap = self.health_bitmap.load(.acquire);\n        const mask: u64 = @as(u64, 1) << idx;\n        return (bitmap & mask) != 0;\n    }\n\n    /// Count healthy backends (atomic read).\n    pub fn countHealthy(self: *const HealthState) u32 {\n        const bitmap = self.health_bitmap.load(.acquire);\n        return @popCount(bitmap & backendMask(self.backend_count));\n    }\n\n    /// Find Nth healthy backend, wrapping around.\n    /// Returns null only if no healthy backends exist.\n    /// Used for round-robin selection across healthy backends.\n    pub fn findNthHealthy(self: *const HealthState, n: u32) ?UpstreamIndex {\n        var bitmap = self.health_bitmap.load(.acquire) & backendMask(self.backend_count);\n\n        const healthy_count = @popCount(bitmap);\n        if (healthy_count == 0) return null;\n\n        var remaining = n % healthy_count;\n        var iterations: u8 = 0;\n\n        while (bitmap != 0 and iterations < MAX_UPSTREAMS) : (iterations += 1) {\n            const lowest_bit_pos: u7 = @ctz(bitmap);\n            if (remaining == 0) {\n                assert(lowest_bit_pos < 64);\n                return @intCast(lowest_bit_pos);\n            }\n            bitmap &= bitmap - 1;\n            remaining -= 1;\n        }\n\n        assert(false);\n        return null;\n    }\n\n    /// Find first healthy backend, optionally excluding one.\n    /// Useful for failover when current backend fails.\n    pub fn findFirstHealthy(self: *const HealthState, exclude_idx: ?UpstreamIndex) ?UpstreamIndex {\n        var bitmap = self.health_bitmap.load(.acquire) & backendMask(self.backend_count);\n\n        if (exclude_idx) |idx| {\n            assert(idx < self.backend_count);\n            bitmap &= ~(@as(u64, 1) << idx);\n        }\n\n        if (bitmap == 0) return null;\n\n        const first: u7 = @ctz(bitmap);\n        assert(first < 64);\n        return @intCast(first);\n    }\n\n    /// Mark backend as healthy (atomic set bit).\n    fn markHealthy(self: *HealthState, idx: UpstreamIndex) void {\n        assert(idx < self.backend_count);\n        const mask: u64 = @as(u64, 1) << idx;\n        _ = self.health_bitmap.fetchOr(mask, .release);\n    }\n\n    /// Mark backend as unhealthy (atomic clear bit).\n    fn markUnhealthy(self: *HealthState, idx: UpstreamIndex) void {\n        assert(idx < self.backend_count);\n        const mask: u64 = @as(u64, 1) << idx;\n        _ = self.health_bitmap.fetchAnd(~mask, .release);\n    }\n\n    /// Reset all backends to healthy and clear counters.\n    pub fn reset(self: *HealthState) void {\n        self.health_bitmap.store(backendMask(self.backend_count), .release);\n        self.failure_counts = std.mem.zeroes([MAX_UPSTREAMS]u8);\n        self.success_counts = std.mem.zeroes([MAX_UPSTREAMS]u8);\n    }\n};\n\n// =============================================================================\n// Tests\n// =============================================================================\n\ntest \"HealthState alignment\" {\n    try std.testing.expectEqual(@as(usize, CACHE_LINE_BYTES), @alignOf(HealthState));\n}\n\ntest \"HealthState init with backend count\" {\n    const state = HealthState.init(3, 3, 2);\n\n    try std.testing.expectEqual(@as(u32, 3), state.countHealthy());\n    try std.testing.expect(state.isHealthy(0));\n    try std.testing.expect(state.isHealthy(1));\n    try std.testing.expect(state.isHealthy(2));\n    try std.testing.expectEqual(@as(u8, 3), state.unhealthy_threshold);\n    try std.testing.expectEqual(@as(u8, 2), state.healthy_threshold);\n}\n\ntest \"HealthState init with zero backends\" {\n    const state = HealthState.init(0, 3, 2);\n    try std.testing.expectEqual(@as(u32, 0), state.countHealthy());\n}\n\ntest \"HealthState init with max backends\" {\n    const state = HealthState.init(MAX_UPSTREAMS, 3, 2);\n    try std.testing.expectEqual(@as(u32, MAX_UPSTREAMS), state.countHealthy());\n    try std.testing.expect(state.isHealthy(0));\n    try std.testing.expect(state.isHealthy(MAX_UPSTREAMS - 1));\n}\n\ntest \"HealthState recordFailure transitions after threshold\" {\n    var state = HealthState.init(3, 3, 2);\n\n    // Start healthy\n    try std.testing.expect(state.isHealthy(0));\n\n    // First two failures - still healthy\n    state.recordFailure(0);\n    try std.testing.expect(state.isHealthy(0));\n    try std.testing.expectEqual(@as(u8, 1), state.failure_counts[0]);\n\n    state.recordFailure(0);\n    try std.testing.expect(state.isHealthy(0));\n    try std.testing.expectEqual(@as(u8, 2), state.failure_counts[0]);\n\n    // Third failure - reaches threshold, now unhealthy\n    state.recordFailure(0);\n    try std.testing.expect(!state.isHealthy(0));\n    try std.testing.expectEqual(@as(u8, 0), state.failure_counts[0]);\n}\n\ntest \"HealthState recordSuccess transitions after threshold\" {\n    var state = HealthState.init(3, 3, 2);\n\n    // Mark backend unhealthy via failures\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(0);\n    try std.testing.expect(!state.isHealthy(0));\n\n    // First success - still unhealthy\n    state.recordSuccess(0);\n    try std.testing.expect(!state.isHealthy(0));\n    try std.testing.expectEqual(@as(u8, 1), state.success_counts[0]);\n\n    // Second success - reaches threshold, now healthy\n    state.recordSuccess(0);\n    try std.testing.expect(state.isHealthy(0));\n    try std.testing.expectEqual(@as(u8, 0), state.success_counts[0]);\n}\n\ntest \"HealthState success resets failure counter\" {\n    var state = HealthState.init(3, 3, 2);\n\n    // Accumulate failures\n    state.recordFailure(0);\n    state.recordFailure(0);\n    try std.testing.expectEqual(@as(u8, 2), state.failure_counts[0]);\n\n    // Single success resets failure counter\n    state.recordSuccess(0);\n    try std.testing.expectEqual(@as(u8, 0), state.failure_counts[0]);\n}\n\ntest \"HealthState failure resets success counter\" {\n    var state = HealthState.init(3, 3, 2);\n\n    // Mark unhealthy first\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(0);\n    try std.testing.expect(!state.isHealthy(0));\n\n    // Accumulate successes\n    state.recordSuccess(0);\n    try std.testing.expectEqual(@as(u8, 1), state.success_counts[0]);\n\n    // Single failure resets success counter\n    state.recordFailure(0);\n    try std.testing.expectEqual(@as(u8, 0), state.success_counts[0]);\n}\n\ntest \"HealthState findNthHealthy\" {\n    var state = HealthState.init(5, 3, 2);\n\n    // Mark some unhealthy: 0, 2 unhealthy; 1, 3, 4 healthy\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(2);\n    state.recordFailure(2);\n    state.recordFailure(2);\n\n    try std.testing.expectEqual(@as(?UpstreamIndex, 1), state.findNthHealthy(0));\n    try std.testing.expectEqual(@as(?UpstreamIndex, 3), state.findNthHealthy(1));\n    try std.testing.expectEqual(@as(?UpstreamIndex, 4), state.findNthHealthy(2));\n    // Wraps around\n    try std.testing.expectEqual(@as(?UpstreamIndex, 1), state.findNthHealthy(3));\n}\n\ntest \"HealthState findFirstHealthy\" {\n    var state = HealthState.init(5, 3, 2);\n\n    try std.testing.expectEqual(@as(?UpstreamIndex, 0), state.findFirstHealthy(null));\n    try std.testing.expectEqual(@as(?UpstreamIndex, 1), state.findFirstHealthy(0));\n\n    // Mark 0-1 unhealthy\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(1);\n    state.recordFailure(1);\n    state.recordFailure(1);\n\n    try std.testing.expectEqual(@as(?UpstreamIndex, 2), state.findFirstHealthy(null));\n}\n\ntest \"HealthState findFirstHealthy returns null when all unhealthy\" {\n    var state = HealthState.init(2, 3, 2);\n\n    // Mark all unhealthy\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(1);\n    state.recordFailure(1);\n    state.recordFailure(1);\n\n    try std.testing.expectEqual(@as(?UpstreamIndex, null), state.findFirstHealthy(null));\n}\n\ntest \"HealthState reset\" {\n    var state = HealthState.init(3, 3, 2);\n\n    // Mark all unhealthy\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(1);\n    state.recordFailure(1);\n    state.recordFailure(1);\n\n    try std.testing.expectEqual(@as(u32, 1), state.countHealthy());\n\n    // Reset\n    state.reset();\n\n    try std.testing.expectEqual(@as(u32, 3), state.countHealthy());\n    try std.testing.expect(state.isHealthy(0));\n    try std.testing.expect(state.isHealthy(1));\n    try std.testing.expect(state.isHealthy(2));\n}\n\ntest \"HealthState fast path when already in target state\" {\n    var state = HealthState.init(3, 3, 2);\n\n    // Already healthy - recordSuccess should be fast path\n    try std.testing.expect(state.isHealthy(0));\n    state.recordSuccess(0);\n    // Success counter should not increment when already healthy\n    try std.testing.expectEqual(@as(u8, 0), state.success_counts[0]);\n\n    // Mark unhealthy\n    state.recordFailure(0);\n    state.recordFailure(0);\n    state.recordFailure(0);\n    try std.testing.expect(!state.isHealthy(0));\n\n    // Already unhealthy - recordFailure should be fast path\n    state.recordFailure(0);\n    // Failure counter should not increment when already unhealthy\n    try std.testing.expectEqual(@as(u8, 0), state.failure_counts[0]);\n}\n","numLines":389,"startLine":1,"totalLines":389}},"sourceToolAssistantUUID":"35be3054-7c1c-46ac-aaf2-b859ef0d21b4","userType":"external","entrypoint":"cli","cwd":"/home/nick/repos/serval","sessionId":"646a4f49-bebb-4328-acf0-8f573ea592f5","version":"2.1.86","gitBranch":"main","slug":"graceful-swimming-stream"}
