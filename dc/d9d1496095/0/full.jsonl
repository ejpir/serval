{"parentUuid":"726342c3-0a64-4d3f-b11a-95bbd43a7a3b","isSidechain":false,"promptId":"39f1c826-35d1-4f99-bd27-915c0f3e917e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XbhPetnHPdLVy6gnri5Pdn","type":"tool_result","content":"1\t//! Probe adapters for protocol-specific probe behavior.\n2\t//!\n3\t//! HTTP adapter preserves current 2xx semantics.\n4\t//! TCP adapter uses connect success semantics (and TLS handshake for tls upstreams).\n5\t//! UDP adapter supports passive-only and active probing modes.\n6\t\n7\tconst std = @import(\"std\");\n8\tconst assert = std.debug.assert;\n9\tconst Io = std.Io;\n10\tconst posix = std.posix;\n11\t\n12\tconst core = @import(\"serval-core\");\n13\tconst net = @import(\"serval-net\");\n14\tconst serval_client = @import(\"serval-client\");\n15\t\n16\tconst Upstream = core.Upstream;\n17\tconst Request = core.types.Request;\n18\tconst Client = serval_client.Client;\n19\tconst DnsResolver = net.DnsResolver;\n20\t\n21\tpub const HttpProbeAdapterContext = struct {\n22\t    client: *Client,\n23\t    health_path: []const u8,\n24\t};\n25\t\n26\tpub fn httpProbe(context: *anyopaque, upstream: Upstream, io: Io) bool {\n27\t    const adapter_context: *HttpProbeAdapterContext = @ptrCast(@alignCast(context));\n28\t    assert(adapter_context.health_path.len > 0);\n29\t\n30\t    return probeHttp(adapter_context.client, upstream, adapter_context.health_path, io);\n31\t}\n32\t\n33\tpub const TcpProbeAdapterContext = struct {\n34\t    client: *Client,\n35\t};\n36\t\n37\tpub fn tcpConnectProbe(context: *anyopaque, upstream: Upstream, io: Io) bool {\n38\t    const adapter_context: *TcpProbeAdapterContext = @ptrCast(@alignCast(context));\n39\t\n40\t    const result = adapter_context.client.connect(upstream, io) catch {\n41\t        return false;\n42\t    };\n43\t\n44\t    result.conn.socket.close();\n45\t    return true;\n46\t}\n47\t\n48\tpub const UdpProbeMode = enum {\n49\t    passive_only,\n50\t    active_send,\n51\t    active_send_expect,\n52\t};\n53\t\n54\tpub const UdpProbeAdapterContext = struct {\n55\t    dns_resolver: *DnsResolver,\n56\t    probe_mode: UdpProbeMode = .passive_only,\n57\t    payload: []const u8 = \"serval-udp-probe\",\n58\t    expect_payload: ?[]const u8 = null,\n59\t    response_timeout_ms: u32 = 500,\n60\t};\n61\t\n62\tpub fn udpProbe(context: *anyopaque, upstream: Upstream, io: Io) bool {\n63\t    const adapter_context: *UdpProbeAdapterContext = @ptrCast(@alignCast(context));\n64\t\n65\t    switch (adapter_context.probe_mode) {\n66\t        .passive_only => return false,\n67\t        .active_send, .active_send_expect => {},\n68\t    }\n69\t\n70\t    assert(adapter_context.payload.len > 0);\n71\t    assert(adapter_context.response_timeout_ms > 0);\n72\t\n73\t    const resolved = adapter_context.dns_resolver.resolve(upstream.host, upstream.port, io) catch {\n74\t        return false;\n75\t    };\n76\t\n77\t    const stream = resolved.address.connect(io, .{ .mode = .datagram }) catch {\n78\t        return false;\n79\t    };\n80\t    defer posix.close(stream.socket.handle);\n81\t\n82\t    const fd = stream.socket.handle;\n83\t    if (fd < 0) return false;\n84\t\n85\t    _ = posix.send(fd, adapter_context.payload, 0) catch {\n86\t        return false;\n87\t    };\n88\t\n89\t    if (adapter_context.probe_mode == .active_send) {\n90\t        return true;\n91\t    }\n92\t\n93\t    const timeout_tv = makeTimeval(adapter_context.response_timeout_ms);\n94\t    posix.setsockopt(fd, posix.SOL.SOCKET, posix.SO.RCVTIMEO, std.mem.asBytes(&timeout_tv)) catch {\n95\t        return false;\n96\t    };\n97\t\n98\t    var response_buf: [256]u8 = std.mem.zeroes([256]u8);\n99\t    const response_len = posix.recv(fd, &response_buf, 0) catch {\n100\t        return false;\n101\t    };\n102\t    if (response_len == 0) return false;\n103\t\n104\t    if (adapter_context.expect_payload) |expected| {\n105\t        if (response_len != expected.len) return false;\n106\t        return std.mem.eql(u8, response_buf[0..response_len], expected);\n107\t    }\n108\t\n109\t    return true;\n110\t}\n111\t\n112\tfn makeTimeval(timeout_ms: u32) posix.timeval {\n113\t    assert(timeout_ms > 0);\n114\t\n115\t    const seconds: i64 = @intCast(timeout_ms / 1000);\n116\t    const micros: i64 = @intCast((timeout_ms % 1000) * 1000);\n117\t\n118\t    return .{\n119\t        .sec = seconds,\n120\t        .usec = micros,\n121\t    };\n122\t}\n123\t\n124\tfn probeHttp(client: *Client, upstream: Upstream, health_path: []const u8, io: Io) bool {\n125\t    assert(upstream.host.len > 0);\n126\t    assert(health_path.len > 0);\n127\t\n128\t    var request = buildHttpProbeRequest(upstream.host, health_path) catch {\n129\t        return false;\n130\t    };\n131\t\n132\t    var header_buf: [1024]u8 = std.mem.zeroes([1024]u8);\n133\t\n134\t    var result = client.request(upstream, &request, &header_buf, io) catch {\n135\t        return false;\n136\t    };\n137\t    result.conn.socket.close();\n138\t\n139\t    return isHttpSuccessStatus(result.response.status);\n140\t}\n141\t\n142\tfn buildHttpProbeRequest(host: []const u8, health_path: []const u8) !Request {\n143\t    assert(host.len > 0);\n144\t    assert(health_path.len > 0);\n145\t\n146\t    var request = Request{\n147\t        .method = .GET,\n148\t        .path = health_path,\n149\t        .version = .@\"HTTP/1.1\",\n150\t        .headers = .{},\n151\t    };\n152\t\n153\t    try request.headers.put(\"Host\", host);\n154\t    try request.headers.put(\"Connection\", \"close\");\n155\t    try request.headers.put(\"User-Agent\", \"serval-prober/1.0\");\n156\t\n157\t    return request;\n158\t}\n159\t\n160\tfn isHttpSuccessStatus(status: u16) bool {\n161\t    return status >= 200 and status < 300;\n162\t}\n163\t\n164\ttest \"makeTimeval converts milliseconds\" {\n165\t    const tv = makeTimeval(1500);\n166\t    try std.testing.expectEqual(@as(i64, 1), tv.sec);\n167\t    try std.testing.expectEqual(@as(i64, 500_000), tv.usec);\n168\t}\n169\t\n170\ttest \"buildHttpProbeRequest preserves legacy probe request shape\" {\n171\t    const request = try buildHttpProbeRequest(\"backend1.example.com\", \"/health\");\n172\t\n173\t    try std.testing.expectEqual(core.types.Method.GET, request.method);\n174\t    try std.testing.expectEqualStrings(\"/health\", request.path);\n175\t    try std.testing.expectEqual(@as(usize, 3), request.headers.count);\n176\t    try std.testing.expectEqualStrings(\"backend1.example.com\", request.headers.get(\"Host\").?);\n177\t    try std.testing.expectEqualStrings(\"close\", request.headers.get(\"Connection\").?);\n178\t    try std.testing.expectEqualStrings(\"serval-prober/1.0\", request.headers.get(\"User-Agent\").?);\n179\t}\n180\t\n181\ttest \"isHttpSuccessStatus keeps legacy 2xx success semantics\" {\n182\t    try std.testing.expect(!isHttpSuccessStatus(199));\n183\t    try std.testing.expect(isHttpSuccessStatus(200));\n184\t    try std.testing.expect(isHttpSuccessStatus(204));\n185\t    try std.testing.expect(isHttpSuccessStatus(299));\n186\t    try std.testing.expect(!isHttpSuccessStatus(300));\n187\t    try std.testing.expect(!isHttpSuccessStatus(503));\n188\t}\n189\t\n190\ttest \"udpProbe passive mode does not actively probe\" {\n191\t    var dns_resolver: DnsResolver = undefined;\n192\t    DnsResolver.init(&dns_resolver, .{});\n193\t\n194\t    var context = UdpProbeAdapterContext{\n195\t        .dns_resolver = &dns_resolver,\n196\t        .probe_mode = .passive_only,\n197\t    };\n198\t\n199\t    const upstream = Upstream{ .host = \"127.0.0.1\", .port = 9999, .idx = 0 };\n200\t    try std.testing.expect(!udpProbe(&context, upstream, undefined));\n201\t}\n202\t"}]},"uuid":"30cd321c-f643-4f3a-b72d-122f50052fd8","timestamp":"2026-03-29T16:25:20.488Z","toolUseResult":{"type":"text","file":{"filePath":"/home/nick/repos/serval/serval-prober/adapters.zig","content":"//! Probe adapters for protocol-specific probe behavior.\n//!\n//! HTTP adapter preserves current 2xx semantics.\n//! TCP adapter uses connect success semantics (and TLS handshake for tls upstreams).\n//! UDP adapter supports passive-only and active probing modes.\n\nconst std = @import(\"std\");\nconst assert = std.debug.assert;\nconst Io = std.Io;\nconst posix = std.posix;\n\nconst core = @import(\"serval-core\");\nconst net = @import(\"serval-net\");\nconst serval_client = @import(\"serval-client\");\n\nconst Upstream = core.Upstream;\nconst Request = core.types.Request;\nconst Client = serval_client.Client;\nconst DnsResolver = net.DnsResolver;\n\npub const HttpProbeAdapterContext = struct {\n    client: *Client,\n    health_path: []const u8,\n};\n\npub fn httpProbe(context: *anyopaque, upstream: Upstream, io: Io) bool {\n    const adapter_context: *HttpProbeAdapterContext = @ptrCast(@alignCast(context));\n    assert(adapter_context.health_path.len > 0);\n\n    return probeHttp(adapter_context.client, upstream, adapter_context.health_path, io);\n}\n\npub const TcpProbeAdapterContext = struct {\n    client: *Client,\n};\n\npub fn tcpConnectProbe(context: *anyopaque, upstream: Upstream, io: Io) bool {\n    const adapter_context: *TcpProbeAdapterContext = @ptrCast(@alignCast(context));\n\n    const result = adapter_context.client.connect(upstream, io) catch {\n        return false;\n    };\n\n    result.conn.socket.close();\n    return true;\n}\n\npub const UdpProbeMode = enum {\n    passive_only,\n    active_send,\n    active_send_expect,\n};\n\npub const UdpProbeAdapterContext = struct {\n    dns_resolver: *DnsResolver,\n    probe_mode: UdpProbeMode = .passive_only,\n    payload: []const u8 = \"serval-udp-probe\",\n    expect_payload: ?[]const u8 = null,\n    response_timeout_ms: u32 = 500,\n};\n\npub fn udpProbe(context: *anyopaque, upstream: Upstream, io: Io) bool {\n    const adapter_context: *UdpProbeAdapterContext = @ptrCast(@alignCast(context));\n\n    switch (adapter_context.probe_mode) {\n        .passive_only => return false,\n        .active_send, .active_send_expect => {},\n    }\n\n    assert(adapter_context.payload.len > 0);\n    assert(adapter_context.response_timeout_ms > 0);\n\n    const resolved = adapter_context.dns_resolver.resolve(upstream.host, upstream.port, io) catch {\n        return false;\n    };\n\n    const stream = resolved.address.connect(io, .{ .mode = .datagram }) catch {\n        return false;\n    };\n    defer posix.close(stream.socket.handle);\n\n    const fd = stream.socket.handle;\n    if (fd < 0) return false;\n\n    _ = posix.send(fd, adapter_context.payload, 0) catch {\n        return false;\n    };\n\n    if (adapter_context.probe_mode == .active_send) {\n        return true;\n    }\n\n    const timeout_tv = makeTimeval(adapter_context.response_timeout_ms);\n    posix.setsockopt(fd, posix.SOL.SOCKET, posix.SO.RCVTIMEO, std.mem.asBytes(&timeout_tv)) catch {\n        return false;\n    };\n\n    var response_buf: [256]u8 = std.mem.zeroes([256]u8);\n    const response_len = posix.recv(fd, &response_buf, 0) catch {\n        return false;\n    };\n    if (response_len == 0) return false;\n\n    if (adapter_context.expect_payload) |expected| {\n        if (response_len != expected.len) return false;\n        return std.mem.eql(u8, response_buf[0..response_len], expected);\n    }\n\n    return true;\n}\n\nfn makeTimeval(timeout_ms: u32) posix.timeval {\n    assert(timeout_ms > 0);\n\n    const seconds: i64 = @intCast(timeout_ms / 1000);\n    const micros: i64 = @intCast((timeout_ms % 1000) * 1000);\n\n    return .{\n        .sec = seconds,\n        .usec = micros,\n    };\n}\n\nfn probeHttp(client: *Client, upstream: Upstream, health_path: []const u8, io: Io) bool {\n    assert(upstream.host.len > 0);\n    assert(health_path.len > 0);\n\n    var request = buildHttpProbeRequest(upstream.host, health_path) catch {\n        return false;\n    };\n\n    var header_buf: [1024]u8 = std.mem.zeroes([1024]u8);\n\n    var result = client.request(upstream, &request, &header_buf, io) catch {\n        return false;\n    };\n    result.conn.socket.close();\n\n    return isHttpSuccessStatus(result.response.status);\n}\n\nfn buildHttpProbeRequest(host: []const u8, health_path: []const u8) !Request {\n    assert(host.len > 0);\n    assert(health_path.len > 0);\n\n    var request = Request{\n        .method = .GET,\n        .path = health_path,\n        .version = .@\"HTTP/1.1\",\n        .headers = .{},\n    };\n\n    try request.headers.put(\"Host\", host);\n    try request.headers.put(\"Connection\", \"close\");\n    try request.headers.put(\"User-Agent\", \"serval-prober/1.0\");\n\n    return request;\n}\n\nfn isHttpSuccessStatus(status: u16) bool {\n    return status >= 200 and status < 300;\n}\n\ntest \"makeTimeval converts milliseconds\" {\n    const tv = makeTimeval(1500);\n    try std.testing.expectEqual(@as(i64, 1), tv.sec);\n    try std.testing.expectEqual(@as(i64, 500_000), tv.usec);\n}\n\ntest \"buildHttpProbeRequest preserves legacy probe request shape\" {\n    const request = try buildHttpProbeRequest(\"backend1.example.com\", \"/health\");\n\n    try std.testing.expectEqual(core.types.Method.GET, request.method);\n    try std.testing.expectEqualStrings(\"/health\", request.path);\n    try std.testing.expectEqual(@as(usize, 3), request.headers.count);\n    try std.testing.expectEqualStrings(\"backend1.example.com\", request.headers.get(\"Host\").?);\n    try std.testing.expectEqualStrings(\"close\", request.headers.get(\"Connection\").?);\n    try std.testing.expectEqualStrings(\"serval-prober/1.0\", request.headers.get(\"User-Agent\").?);\n}\n\ntest \"isHttpSuccessStatus keeps legacy 2xx success semantics\" {\n    try std.testing.expect(!isHttpSuccessStatus(199));\n    try std.testing.expect(isHttpSuccessStatus(200));\n    try std.testing.expect(isHttpSuccessStatus(204));\n    try std.testing.expect(isHttpSuccessStatus(299));\n    try std.testing.expect(!isHttpSuccessStatus(300));\n    try std.testing.expect(!isHttpSuccessStatus(503));\n}\n\ntest \"udpProbe passive mode does not actively probe\" {\n    var dns_resolver: DnsResolver = undefined;\n    DnsResolver.init(&dns_resolver, .{});\n\n    var context = UdpProbeAdapterContext{\n        .dns_resolver = &dns_resolver,\n        .probe_mode = .passive_only,\n    };\n\n    const upstream = Upstream{ .host = \"127.0.0.1\", .port = 9999, .idx = 0 };\n    try std.testing.expect(!udpProbe(&context, upstream, undefined));\n}\n","numLines":202,"startLine":1,"totalLines":202}},"sourceToolAssistantUUID":"726342c3-0a64-4d3f-b11a-95bbd43a7a3b","userType":"external","entrypoint":"cli","cwd":"/home/nick/repos/serval","sessionId":"646a4f49-bebb-4328-acf0-8f573ea592f5","version":"2.1.86","gitBranch":"main","slug":"graceful-swimming-stream"}
