n41\t    probe_timeout_ms: u32 = config.DEFAULT_PROBE_TIMEOUT_MS,\n42\t    /// Health check path.\n43\t    health_path: []const u8 = config.DEFAULT_HEALTH_PATH,\n44\t};\n45\t\n46\t/// Load balancer handler with health tracking and automatic probing.\n47\t///\n48\t/// Features:\n49\t/// - Health-aware round-robin selection (skips unhealthy backends)\n50\t/// - Passive health updates via onLog (5xx = failure)\n51\t/// - Active background probing for recovery\n52\t/// - Graceful degradation when all backends unhealthy\n53\t///\n54\t/// TigerStyle: Embedded protocol-agnostic strategy core, bounded by MAX_UPSTREAMS.\n55\tpub const LbHandler = struct {\n56\t    upstreams: []const Upstream,\n57\t    strategy: RoundRobinStrategy,\n58\t    probe_running: std.atomic.Value(bool),\n59\t    probe_thread: ?std.Thread,\n60\t    lb_config: LbConfig,\n61\t\n62\t    const Self = @This();\n63\t\n64\t    /// Initialize load balancer and start background prober.\n65\t    /// TigerStyle C3: Out-pointer for large struct, stable pointer for thread.\n66\t    /// TigerStyle: Caller provides SSL_CTX for TLS probes (caller owns lifetime).\n67\t    ///\n68\t    /// client_ctx: SSL_CTX for TLS health probes (required if any upstream has tls=true).\n69\t    ///             Caller is responsible for creating and freeing the context.\n70\t    ///             Pass null if all upstreams are plain HTTP.\n71\t    /// dns_resolver: DNS resolver for hostname resolution in health probes.\n72\t    ///               Required if probing is enabled. Caller owns lifetime.\n73\t    pub fn init(\n74\t        self: *Self,\n75\t        upstreams: []const Upstream,\n76\t        lb_config: LbConfig,\n77\t        client_ctx: ?*ssl.SSL_CTX,\n78\t        dns_resolver: ?*DnsResolver,\n79\t    ) !void {\n80\t        assert(upstreams.len > 0);\n81\t        assert(upstreams.len <= MAX_UPSTREAMS);\n82\t        assert(lb_config.probe_interval_ms > 0);\n83\t        assert(lb_config.probe_timeout_ms > 0);\n84\t        // S1: if probing enabled, dns_resolver must be provided\n85\t        assert(!lb_config.enable_probing or dns_resolver != null);\n86\t\n87\t        self.* = .{\n88\t            .upstreams = upstreams,\n89\t            .strategy = undefined,\n90\t            .probe_running = std.atomic.Value(bool).init(false),\n91\t            .probe_thread = null,\n92\t            .lb_config = lb_config,\n93\t        };\n94\t\n95\t        self.strategy.init(upstreams, StrategyConfig{\n96\t            .unhealthy_threshold = lb_config.unhealthy_threshold,\n97\t            .healthy_threshold = lb_config.healthy_threshold,\n98\t        });\n99\t\n100\t        // Start background prober if enabled\n101\t        if (lb_config.enable_probing) {\n102\t            self.probe_running.store(true, .release);\n103\t            const ctx = prober.ProberContext{\n104\t                .upstreams = upstreams,\n105\t                .health = self.strategy.healthPtr(),\n106\t                .probe_running = &self.probe_running,\n107\t                .probe_interval_ms = lb_config.probe_interval_ms,\n108\t                .probe_timeout_ms = lb_config.probe_timeout_ms,\n109\t                .health_path = lb_config.health_path,\n110\t                .client_ctx = client_ctx,\n111\t                .dns_resolver = dns_resolver.?,\n112\t            };\n113\t            self.probe_thread = try std.Thread.spawn(.{}, prober.probeLoop, .{ctx});\n114\t        }\n115\t    }\n116\t\n117\t    /// Stop background prober and clean up.\n118\t    pub fn deinit(self: *Self) void {\n119\t        // Signal prober to stop\n120\t        self.probe_running.store(false, .release);\n121\t\n122\t        // Wait for thread to exit\n123\t        if (self.probe_thread) |thread| {\n124\t            thread.join();\n125\t            self.probe_thread = null;\n126\t        }\n127\t    }\n128\t\n129\t    /// Health-aware round-robin selection.\n130\t    /// Falls back to simple round-robin if all backends unhealthy.\n131\t    pub fn selectUpstream(self: *Self, ctx: *Context, request: *const Request) Upstream {\n132\t        _ = ctx;\n133\t        _ = request;\n134\t        assert(self.upstreams.len > 0);\n135\t\n136\t        return self.strategy.select();\n137\t    }\n138\t\n139\t    /// Record request outcome for passive health tracking.\n140\t    /// 5xx responses count as failures, everything else as success.\n141\t    pub fn onLog(self: *Self, ctx: *Context, entry: LogEntry) void {\n142\t        _ = ctx;\n143\t\n144\t        const upstream = entry.upstream orelse return;\n145\t\n146\t        assert(upstream.idx < MAX_UPSTREAMS);\n147\t        const idx: UpstreamIndex = @intCast(upstream.idx);\n148\t\n149\t        if (entry.status >= 500) {\n150\t            self.strategy.recordFailure(idx);\n151\t        } else {\n152\t            self.strategy.recordSuccess(idx);\n153\t        }\n154\t    }\n155\t\n156\t    /// Count healthy backends (for observability).\n157\t    pub fn countHealthy(self: *const Self) u32 {\n158\t        return self.strategy.countHealthy();\n159\t    }\n160\t\n161\t    /// Check if specific backend is healthy.\n162\t    pub fn isHealthy(self: *const Self, idx: UpstreamIndex) bool {\n163\t        assert(idx < self.upstreams.len);\n164\t        return self.strategy.isHealthy(idx);\n165\t    }\n166\t};\n167\t\n168\t// =============================================================================\n169\t// Tests\n170\t// =============================================================================\n171\t\n172\tfn makeLogEntry(status: u16, upstream_idx: UpstreamIndex) LogEntry {\n173\t    return .{\n174\t        .timestamp_s = 0,\n175\t        .start_time_ns = 0,\n176\t        .duration_ns = 0,\n177\t        .method = .GET,\n178\t        .path = \"/\",\n179\t        .request_bytes = 0,\n180\t        .status = status,\n181\t        .response_bytes = 0,\n182\t        .upstream = .{ .host = \"backend\", .port = 8000, .idx = upstream_idx },\n183\t        .upstream_duration_ns = 0,\n184\t        .error_phase = null,\n185\t        .error_name = null,\n186\t        .connection_reused = false,\n187\t        .keepalive = true,\n188\t    };\n189\t}\n190\t\n191\ttest \"LbHandler init and deinit\" {\n192\t    const upstreams = [_]Upstream{\n193\t        .{ .host = \"127.0.0.1\", .port = 8001, .idx = 0 },\n194\t        .{ .host = \"127.0.0.1\", .port = 8002, .idx = 1 },\n195\t    };\n196\t\n197\t    // Disable probing for tests (no real backends)\n198\t    var handler: LbHandler = undefined;\n199\t    try handler.init(&upstreams, .{ .enable_probing = false }, null, null);\n200\t    defer handler.deinit();\n201\t\n202\t    try std.testing.expect(!handler.probe_running.load(.acquire));\n203\t    try std.testing.expect(handler.probe_thread == null);\n204\t}\n205\t\n206\ttest \"LbHandler selectUpstream round-robin\" {\n207\t    const upstreams = [_]Upstream{\n208\t        .{ .host = \"127.0.0.1\", .port = 8001, .idx = 0 },\n209\t        .{ .host = \"127.0.0.1\", .port = 8002, .idx = 1 },\n210\t        .{ .host = \"127.0.0.1\", .port = 8003, .idx = 2 },\n211\t    };\n212\t\n213\t    var handler: LbHandler = undefined;\n214\t    try handler.init(&upstreams, .{ .enable_probing = false }, null, null);\n215\t    defer handler.deinit();\n216\t\n217\t    var ctx = Context.init();\n218\t    const request = Request{};\n219\t\n220\t    // All healthy - cycles through all\n221\t    const first = handler.selectUpstream(&ctx, &request);\n222\t    try std.testing.expectEqual(@as(u16, 8001), first.port);\n223\t\n224\t    const second = handler.selectUpstream(&ctx, &request);\n225\t    try std.testing.expectEqual(@as(u16, 8002), second.port);\n226\t\n227\t    const third = handler.selectUpstream(&ctx, &request);\n228\t    try std.testing.expectEqual(@as(u16, 8003), third.port);\n229\t\n230\t    // Wraps around\n231\t    const fourth = handler.selectUpstream(&ctx, &request);\n232\t    try std.testing.expectEqual(@as(u16, 8001), fourth.port);\n233\t}\n234\t\n235\ttest \"LbHandler sk