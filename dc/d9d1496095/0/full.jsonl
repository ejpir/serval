{"parentUuid":"10d1ae0c-ea82-4b74-ad65-d7e4e595ba4d","isSidechain":false,"promptId":"39f1c826-35d1-4f99-bd27-915c0f3e917e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MWqJYoBxQ1r6o2mVB2XGvV","type":"tool_result","content":"1\t//! Shared probe scheduler core.\n2\t//!\n3\t//! Protocol-agnostic loop/scheduling + health update behavior.\n4\t\n5\tconst std = @import(\"std\");\n6\tconst assert = std.debug.assert;\n7\tconst Io = std.Io;\n8\t\n9\tconst core = @import(\"serval-core\");\n10\tconst log = core.log.scoped(.prober_scheduler);\n11\tconst health_mod = @import(\"serval-health\");\n12\t\n13\tconst Upstream = core.Upstream;\n14\tconst HealthState = health_mod.HealthState;\n15\tconst UpstreamIndex = core.config.UpstreamIndex;\n16\t\n17\tpub const ProbeAdapter = struct {\n18\t    context: *anyopaque,\n19\t    probeFn: *const fn (context: *anyopaque, upstream: Upstream, io: Io) bool,\n20\t};\n21\t\n22\tpub const SchedulerContext = struct {\n23\t    upstreams: []const Upstream,\n24\t    health: *HealthState,\n25\t    probe_running: *std.atomic.Value(bool),\n26\t    probe_interval_ms: u32,\n27\t    adapter: ProbeAdapter,\n28\t};\n29\t\n30\tpub fn runLoopWithIo(ctx: SchedulerContext, io: Io) void {\n31\t    assert(ctx.probe_interval_ms > 0);\n32\t\n33\t    const interval_duration = std.Io.Duration.fromMilliseconds(@intCast(ctx.probe_interval_ms));\n34\t\n35\t    while (ctx.probe_running.load(.acquire)) {\n36\t        probeUnhealthyOnce(ctx, io);\n37\t        std.Io.sleep(std.Options.debug_io, interval_duration, .awake) catch |err| {\n38\t            log.debug(\"scheduler: sleep failed: {s}\", .{@errorName(err)});\n39\t        };\n40\t    }\n41\t}\n42\t\n43\tpub fn probeUnhealthyOnce(ctx: SchedulerContext, io: Io) void {\n44\t    assert(ctx.upstreams.len > 0);\n45\t\n46\t    for (ctx.upstreams, 0..) |upstream, idx_usize| {\n47\t        const idx: UpstreamIndex = @intCast(idx_usize);\n48\t\n49\t        if (ctx.health.isHealthy(idx)) continue;\n50\t\n51\t        const success = ctx.adapter.probeFn(ctx.adapter.context, upstream, io);\n52\t        if (success) {\n53\t            ctx.health.recordSuccess(idx);\n54\t        }\n55\t    }\n56\t}\n57\t\n58\ttest \"probeUnhealthyOnce records success for unhealthy backend\" {\n59\t    const AdapterContext = struct {\n60\t        fn probe(context: *anyopaque, upstream: Upstream, io: Io) bool {\n61\t            _ = context;\n62\t            _ = io;\n63\t            return upstream.idx == 1;\n64\t        }\n65\t    };\n66\t\n67\t    const upstreams = [_]Upstream{\n68\t        .{ .host = \"127.0.0.1\", .port = 8001, .idx = 0 },\n69\t        .{ .host = \"127.0.0.1\", .port = 8002, .idx = 1 },\n70\t    };\n71\t\n72\t    var health = HealthState.init(2, 1, 1);\n73\t    health.recordFailure(1);\n74\t\n75\t    var running = std.atomic.Value(bool).init(true);\n76\t    var adapter_marker: u8 = 0;\n77\t\n78\t    const ctx = SchedulerContext{\n79\t        .upstreams = &upstreams,\n80\t        .health = &health,\n81\t        .probe_running = &running,\n82\t        .probe_interval_ms = 100,\n83\t        .adapter = .{\n84\t            .context = &adapter_marker,\n85\t            .probeFn = AdapterContext.probe,\n86\t        },\n87\t    };\n88\t\n89\t    try std.testing.expect(!health.isHealthy(1));\n90\t    probeUnhealthyOnce(ctx, undefined);\n91\t    try std.testing.expect(health.isHealthy(1));\n92\t}\n93\t"}]},"uuid":"db27230d-1ce7-43d3-b60c-306ca22aabfb","timestamp":"2026-03-29T16:25:20.050Z","toolUseResult":{"type":"text","file":{"filePath":"/home/nick/repos/serval/serval-prober/scheduler.zig","content":"//! Shared probe scheduler core.\n//!\n//! Protocol-agnostic loop/scheduling + health update behavior.\n\nconst std = @import(\"std\");\nconst assert = std.debug.assert;\nconst Io = std.Io;\n\nconst core = @import(\"serval-core\");\nconst log = core.log.scoped(.prober_scheduler);\nconst health_mod = @import(\"serval-health\");\n\nconst Upstream = core.Upstream;\nconst HealthState = health_mod.HealthState;\nconst UpstreamIndex = core.config.UpstreamIndex;\n\npub const ProbeAdapter = struct {\n    context: *anyopaque,\n    probeFn: *const fn (context: *anyopaque, upstream: Upstream, io: Io) bool,\n};\n\npub const SchedulerContext = struct {\n    upstreams: []const Upstream,\n    health: *HealthState,\n    probe_running: *std.atomic.Value(bool),\n    probe_interval_ms: u32,\n    adapter: ProbeAdapter,\n};\n\npub fn runLoopWithIo(ctx: SchedulerContext, io: Io) void {\n    assert(ctx.probe_interval_ms > 0);\n\n    const interval_duration = std.Io.Duration.fromMilliseconds(@intCast(ctx.probe_interval_ms));\n\n    while (ctx.probe_running.load(.acquire)) {\n        probeUnhealthyOnce(ctx, io);\n        std.Io.sleep(std.Options.debug_io, interval_duration, .awake) catch |err| {\n            log.debug(\"scheduler: sleep failed: {s}\", .{@errorName(err)});\n        };\n    }\n}\n\npub fn probeUnhealthyOnce(ctx: SchedulerContext, io: Io) void {\n    assert(ctx.upstreams.len > 0);\n\n    for (ctx.upstreams, 0..) |upstream, idx_usize| {\n        const idx: UpstreamIndex = @intCast(idx_usize);\n\n        if (ctx.health.isHealthy(idx)) continue;\n\n        const success = ctx.adapter.probeFn(ctx.adapter.context, upstream, io);\n        if (success) {\n            ctx.health.recordSuccess(idx);\n        }\n    }\n}\n\ntest \"probeUnhealthyOnce records success for unhealthy backend\" {\n    const AdapterContext = struct {\n        fn probe(context: *anyopaque, upstream: Upstream, io: Io) bool {\n            _ = context;\n            _ = io;\n            return upstream.idx == 1;\n        }\n    };\n\n    const upstreams = [_]Upstream{\n        .{ .host = \"127.0.0.1\", .port = 8001, .idx = 0 },\n        .{ .host = \"127.0.0.1\", .port = 8002, .idx = 1 },\n    };\n\n    var health = HealthState.init(2, 1, 1);\n    health.recordFailure(1);\n\n    var running = std.atomic.Value(bool).init(true);\n    var adapter_marker: u8 = 0;\n\n    const ctx = SchedulerContext{\n        .upstreams = &upstreams,\n        .health = &health,\n        .probe_running = &running,\n        .probe_interval_ms = 100,\n        .adapter = .{\n            .context = &adapter_marker,\n            .probeFn = AdapterContext.probe,\n        },\n    };\n\n    try std.testing.expect(!health.isHealthy(1));\n    probeUnhealthyOnce(ctx, undefined);\n    try std.testing.expect(health.isHealthy(1));\n}\n","numLines":93,"startLine":1,"totalLines":93}},"sourceToolAssistantUUID":"10d1ae0c-ea82-4b74-ad65-d7e4e595ba4d","userType":"external","entrypoint":"cli","cwd":"/home/nick/repos/serval","sessionId":"646a4f49-bebb-4328-acf0-8f573ea592f5","version":"2.1.86","gitBranch":"main","slug":"graceful-swimming-stream"}
