# Serval NetBird reverse-proxy configuration
#
# Usage:
#   zig build run-netbird-proxy -- --config deploy/examples/netbird/serval-netbird.conf.example
#
# Frontend listen host/address.
#   0.0.0.0 -> IPv4 only
#   ::      -> IPv6 any (typically dual-stack, kernel dependent)
listen_host=0.0.0.0

# Frontend listen port. If omitted, CLI --port (default 8080) is used.
listen_port=443

# Frontend TLS cert/key (self-signed supported)
# Example self-signed cert generation:
#   openssl req -x509 -newkey rsa:4096 -sha256 -days 365 \
#     -nodes -keyout /etc/serval/netbird-selfsigned.key \
#     -out /etc/serval/netbird-selfsigned.crt \
#     -subj "/CN=netbird.local"
cert_path=/etc/serval/netbird-selfsigned.crt
key_path=/etc/serval/netbird-selfsigned.key

# Verify certificates when upstream specs use TLS schemes (https:// or h2://)
verify_upstream=false

# TLS frontend HTTP/2 dispatch mode
#   disabled         -> disable explicit frontend-h2 policy routing
#                       (ALPN-negotiated h2 may still use generic fallback for protocol safety)
#   terminated_only  -> prefer terminated h2 handlers; ALPN h2 without terminated hooks falls back to generic frontend h2
#   generic          -> generic frontend h2 for ALPN h2 when terminated hooks are absent
# Keep terminated_only for mixed web+gRPC endpoints unless fully validated.
tls_h2_frontend_mode=terminated_only

# ALPN negotiation policy for TLS frontend connections
#   prefer_http11    -> accept h2 if client only offers h2, prefer http/1.1 on mixed offers
#   prefer_h2        -> prefer h2 on mixed offers (recommended when you want browser/UI paths to negotiate h2)
#   http11_only      -> reject h2 ALPN; forces gRPC clients to use WebSocket fallback
alpn_mixed_offer_policy=prefer_h2

# Scanner-blocking WAF controls
#   waf_block_threshold   -> cumulative score threshold for non-direct-block rules
#   waf_enforcement_mode  -> detect_only | enforce
#   waf_failure_mode      -> fail_open | fail_closed
waf_block_threshold=100
waf_enforcement_mode=enforce
waf_failure_mode=fail_open

# Behavioral burst detection controls
#   waf_burst_window_ns              -> tumbling window duration (nanoseconds)
#   waf_burst_tracker_capacity       -> max tracked clients in table
#   waf_burst_request_threshold      -> requests per window signal threshold
#   waf_burst_unique_path_threshold  -> distinct normalized paths per window threshold
#   waf_burst_namespace_threshold    -> sensitive namespace family threshold
#   waf_burst_miss_reject_threshold  -> misses/rejects per window threshold
waf_burst_window_ns=10000000000
waf_burst_tracker_capacity=256
waf_burst_request_threshold=20
waf_burst_unique_path_threshold=16
waf_burst_namespace_threshold=3
waf_burst_miss_reject_threshold=10

# Upstream matrix
#
# Allowed schemes:
#   http://host:port   -> HTTP/1.1 plaintext
#   https://host:port  -> HTTP/1.1 over TLS
#   h2c://host:port    -> HTTP/2 cleartext (for h2 upstream paths)
#   h2://host:port     -> HTTP/2 over TLS (ALPN h2)

signal_grpc=h2c://signal:10000
management_grpc=h2c://management:80
signal_http=http://signal:80
management_http=http://management:80
relay_http=http://relay:80
dashboard_http=http://dashboard:80
zitadel_http=h2c://zitadel:8080
