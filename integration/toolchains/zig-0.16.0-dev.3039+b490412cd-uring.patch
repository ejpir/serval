+fn posixConnectWithTimeout(
+    t: *Threaded,
+    socket_fd: posix.socket_t,
+    addr: *const posix.sockaddr,
+    addr_len: posix.socklen_t,
+    timeout: Io.Timeout,
+) IpAddress.ConnectError!void {
+    const original_flags = try posixGetStatusFlags(socket_fd);
+    var nonblocking_flags = original_flags;
+    nonblocking_flags |= @as(usize, 1 << @bitOffsetOf(posix.O, "NONBLOCK"));
+    if (nonblocking_flags != original_flags) try posixSetStatusFlags(socket_fd, nonblocking_flags);
+    defer if (nonblocking_flags != original_flags) posixSetStatusFlags(socket_fd, original_flags) catch {};
+
+    posixConnect(socket_fd, addr, addr_len) catch |err| switch (err) {
+        error.WouldBlock, error.ConnectionPending => {},
+        else => |e| return e,
+    };
+
+    const t_io = io(t);
+    const deadline = timeout.toTimestamp(t_io);
+    var poll_fd: [1]posix.pollfd = .{.{
+        .fd = socket_fd,
+        .events = posix.POLL.OUT | posix.POLL.ERR,
+        .revents = 0,
+    }};
+
+    while (true) {
+        const timeout_ms: i32 = t: {
+            const d = deadline orelse break :t -1;
+            const duration = d.durationFromNow(t_io);
+            break :t @min(@max(0, duration.raw.toMilliseconds()), std.math.maxInt(i32));
+        };
+        const syscall = try Syscall.start();
+        const rc = posix.system.poll(&poll_fd, 1, timeout_ms);
+        switch (posix.errno(rc)) {
+            .SUCCESS => {
+                syscall.finish();
+                if (rc == 0) {
+                    if (deadline == null) continue;
+                    return error.Timeout;
+                }
+                posixConnectCheckSoError(socket_fd) catch |err| switch (err) {
+                    error.WouldBlock, error.ConnectionPending => continue,
+                    else => |e| return e,
+                };
+                return;
+            },
+            .INTR => {
+                try syscall.checkCancel();
+                continue;
+            },
+            .BADF => return syscall.errnoBug(.BADF),
+            .FAULT => return syscall.errnoBug(.FAULT),
+            .INVAL => return syscall.errnoBug(.INVAL),
+            else => |e| return syscall.unexpectedErrno(e),
+        }
+    }
+}
+
+fn posixConnectCheckSoError(socket_fd: posix.socket_t) IpAddress.ConnectError!void {
+    var so_error: c_int = 0;
+    var opt_len: posix.socklen_t = @sizeOf(c_int);
+    const syscall: Syscall = try .start();
+    while (true) {
+        switch (posix.errno(posix.system.getsockopt(
+            socket_fd,
+            posix.SOL.SOCKET,
+            posix.SO.ERROR,
+            @ptrCast(&so_error),
+            &opt_len,
+        ))) {
+            .SUCCESS => {
+                syscall.finish();
+                if (so_error == 0) return;
+                const connect_errno: posix.E = @enumFromInt(so_error);
+                return switch (connect_errno) {
+                    .ADDRNOTAVAIL => error.AddressUnavailable,
+                    .AFNOSUPPORT => error.AddressFamilyUnsupported,
+                    .AGAIN, .INPROGRESS => error.WouldBlock,
+                    .ALREADY => error.ConnectionPending,
+                    .CONNREFUSED => error.ConnectionRefused,
+                    .CONNRESET => error.ConnectionResetByPeer,
+                    .HOSTUNREACH => error.HostUnreachable,
+                    .NETUNREACH => error.NetworkUnreachable,
+                    .TIMEDOUT => error.Timeout,
+                    .ACCES => error.AccessDenied,
+                    .NETDOWN => error.NetworkDown,
+                    .BADF => |err| errnoBug(err),
+                    .CONNABORTED => |err| errnoBug(err),
+                    .FAULT => |err| errnoBug(err),
+                    .ISCONN => |err| errnoBug(err),
+                    .NOENT => |err| errnoBug(err),
+                    .NOTSOCK => |err| errnoBug(err),
+                    .PERM => |err| errnoBug(err),
+                    .PROTOTYPE => |err| errnoBug(err),
+                    else => |err| posix.unexpectedErrno(err),
+                };
+            },
+            .INTR => {
+                try syscall.checkCancel();
+                continue;
+            },
+            .BADF => |err| return syscall.errnoBug(err),
+            .FAULT => |err| return syscall.errnoBug(err),
+            .INVAL => |err| return syscall.errnoBug(err),
+            .NOTSOCK => |err| return syscall.errnoBug(err),
+            else => |err| return syscall.unexpectedErrno(err),
+        }
+    }
+}
+
+fn posixGetStatusFlags(fd: posix.fd_t) IpAddress.ConnectError!usize {
+    const syscall: Syscall = try .start();
+    while (true) {
+        const rc = posix.system.fcntl(fd, posix.F.GETFL, @as(usize, 0));
+        switch (posix.errno(rc)) {
+            .SUCCESS => {
+                syscall.finish();
+                return @intCast(rc);
+            },
+            .INTR => {
+                try syscall.checkCancel();
+                continue;
+            },
+            .BADF => |err| return syscall.errnoBug(err),
+            else => |err| return syscall.unexpectedErrno(err),
+        }
+    }
+}
+
+fn posixSetStatusFlags(fd: posix.fd_t, flags: usize) IpAddress.ConnectError!void {
+    const syscall: Syscall = try .start();
+    while (true) {
+        switch (posix.errno(posix.system.fcntl(fd, posix.F.SETFL, flags))) {
+            .SUCCESS => {
+                syscall.finish();
+                return;
+            },
+            .INTR => {
+                try syscall.checkCancel();
+                continue;
+            },
+            .BADF => |err| return syscall.errnoBug(err),
+            .INVAL => |err| return syscall.errnoBug(err),
+            else => |err| return syscall.unexpectedErrno(err),
+        }
+    }
+}
